#include<biits/stdc++.h>
using namespace std;
int main()
{
 string s;
getline(cin,s);
vector<int> arr;
if(s.front()=='[' && s.back()==']')
{
s = substr(1,s.length()-2);
}
stringstream ss(s);
string num;
while(getline(ss,num,','))
{
arr.pushback(stoi(num));
}
for(int ans:arr)
{
cout<<ans<<" ";
}
}
