Given an integer array nums, move all 0's to the end of it while maintaining the relative order of the non-zero elements.
Note that you must do this in-place without making a copy of the array.
Example 1:
Input: nums = [0,1,0,3,12]
Output: [1,3,12,0,0]
Example 2:
Input: nums = [0]
Output: [0]

 // C language 
void moveZeroes(int* nums, int numsize) {
int left = 0;                                 //one pointer to traverse the array
for(int right = 0; right < numsize; right++)  // another pointer
{
  if(nums[right]!=0)                               //if the value is other than 0 it will go inside
{
  int temp = nums[left];                        //swapping the non zero values one by one makes 0s to move end
  nums[left] = nums[right];
  nums[right] = temp;
  left++;
}}
  for(int i=0; i < numsize; i++)
{
  printf("%d",nums[i]);
}}

//C++ language 
class Solution:
public: 
void moveZeroes(vector<int>& nums) {
  int left = 0;
  for(int right = 0; right < nums.size(); right++)
{
  if(nums[right]!=0)
  {
      swap(nums[left], nums[right]);
      left++;
}}
 for(int i=0;i<nums.size();i++)
{
  cout << nums[i] <<" ";
}}
